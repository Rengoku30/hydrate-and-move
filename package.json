{
  "name": "hydrate-and-move",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Wellness Chrome extension that nudges you to drink water and move, with smart Do-Not-Disturb during meetings.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build",
    "icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\""
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.0.280",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
